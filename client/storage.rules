rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow access to ticket files for authenticated users
    match /tickets/{ticketId}/{fileName} {
      allow read, write: if request.auth != null;
    }
    
    // Allow access to all files for authenticated users
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // For development only - allow all access (NOT for production)
    // Uncomment the following rule for development without authentication
    // match /{allPaths=**} {
    //   allow read, write: if true;
    // }
  }
}